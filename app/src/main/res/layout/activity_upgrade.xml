<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#120A1E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- Close button -->
        <TextView
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/text_white"
            android:textSize="20sp" />

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unlock Premium / Genda VIP 👑"
                android:textColor="@color/gold"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Accelerate your language journey with zero limits."
                android:textColor="@color/text_gray_light"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Feature list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <LinearLayout style="@style/VipFeatureRow">
                <TextView style="@style/VipCheckmark" />
                <TextView style="@style/VipFeatureLabel" android:text="No Ads — study with 100% focus" />
            </LinearLayout>

            <LinearLayout style="@style/VipFeatureRow">
                <TextView style="@style/VipCheckmark" />
                <TextView style="@style/VipFeatureLabel" android:text="Offline Mode — download all flashcards" />
            </LinearLayout>

            <LinearLayout style="@style/VipFeatureRow">
                <TextView style="@style/VipCheckmark" />
                <TextView style="@style/VipFeatureLabel" android:text="Unlimited Decks — create custom categories" />
            </LinearLayout>

            <LinearLayout style="@style/VipFeatureRow">
                <TextView style="@style/VipCheckmark" />
                <TextView style="@style/VipFeatureLabel" android:text="Advanced Analytics — track retention" />
            </LinearLayout>
        </LinearLayout>

        <!-- Pricing cards -->
        <LinearLayout
            android:id="@+id/cardMonthly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_pricing_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly"
                android:textColor="@color/text_white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="$4.99 / month"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:id="@+id/cardAnnual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pricing_card_highlighted"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Annual — Best Value"
                    android:textColor="@color/gold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="$29.99 / year (Save 50%)"
                    android:textColor="@color/text_white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:background="@drawable/bg_popular_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="POPULAR"
                android:textColor="@color/black"
                android:textSize="10sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- CTA -->
        <Button
            android:id="@+id/btnUpgrade"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_gold"
            android:text="Start 7-Day Free Trial"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Cancel anytime. Terms of Service &amp; Privacy Policy."
            android:textColor="@color/text_gray"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>
